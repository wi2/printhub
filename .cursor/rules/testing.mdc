## Integration Tests (Vitest + RTL + MSW)

**What belongs here:** a complete feature slice — real components, real hooks, real store, API mocked at the network layer. Tests that wiring bugs that unit and component tests cannot see.

**Set up default handlers in `beforeEach`. Override per-test for error and edge cases only.**

```typescript
// features/alerts/__tests__/AlertFeature.test.tsx
describe('Alerts feature', () => {
  beforeEach(() => {
    server.use(
      http.get('/api/alerts', () => HttpResponse.json([makeAlert(), makeAlert(), makeAlert()])),
      http.delete('/api/alerts/:id', () => new HttpResponse(null, { status: 204 })),
    );
  });

  it('displays the alert count in the header', async () => {
    render(<AlertsFeature />);
    await screen.findByText('3 active alerts');
  });

  it('decrements the count and removes the item after dismissal', async () => {
    const user = userEvent.setup();
    render(<AlertsFeature />);
    const [first] = await screen.findAllByRole('listitem');
    const title = first.textContent;

    await user.click(within(first).getByRole('button', { name: /dismiss/i }));

    await waitFor(() => expect(screen.queryByText(title!)).not.toBeInTheDocument());
    await screen.findByText('2 active alerts');
  });

  it('shows an inline error and keeps the item when dismissal fails', async () => {
    server.use(http.delete('/api/alerts/:id', () => HttpResponse.error()));
    const user = userEvent.setup();
    render(<AlertsFeature />);
    const [first] = await screen.findAllByRole('listitem');

    await user.click(within(first).getByRole('button', { name: /dismiss/i }));

    await screen.findByRole('alert', { name: /failed to dismiss/i });
    expect(screen.getAllByRole('listitem')).toHaveLength(3); // item not removed
  });
});
```

