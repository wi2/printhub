## Hook Tests (Vitest + RTL)

**Cover parameter changes and error paths, not just the success path.**

```typescript
// useAlerts.test.ts
describe('useAlerts', () => {
  it('returns alerts for the given orgId', async () => {
    server.use(http.get('/api/orgs/:orgId/alerts', () => HttpResponse.json([makeAlert()])));
    const { result } = renderHook(() => useAlerts(toOrgId('org-1')), { wrapper: createWrapper() });
    await waitFor(() => expect(result.current.isSuccess).toBe(true));
    expect(result.current.data).toHaveLength(1);
  });

  it('returns an error when the request fails', async () => {
    server.use(http.get('/api/orgs/:orgId/alerts', () => HttpResponse.error()));
    const { result } = renderHook(() => useAlerts(toOrgId('org-1')), { wrapper: createWrapper() });
    await waitFor(() => expect(result.current.isError).toBe(true));
  });

  it('re-fetches when orgId changes', async () => {
    server.use(http.get('/api/orgs/:orgId/alerts', ({ params }) =>
      HttpResponse.json([makeAlert({ title: `Alert for ${params.orgId}` })])
    ));
    const { result, rerender } = renderHook(
      ({ orgId }) => useAlerts(orgId),
      { wrapper: createWrapper(), initialProps: { orgId: toOrgId('org-1') } }
    );
    await waitFor(() => expect(result.current.isSuccess).toBe(true));
    expect(result.current.data?.[0].title).toContain('org-1');

    rerender({ orgId: toOrgId('org-2') });
    await waitFor(() => expect(result.current.data?.[0].title).toContain('org-2'));
  });
});
```

