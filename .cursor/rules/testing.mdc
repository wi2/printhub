## Zustand Store Tests

Test slices in isolation using `createStore` directly — never import the root store in unit tests.

```typescript
// src/store/filtersSlice.test.ts
import { createStore } from 'zustand';
import { createFiltersSlice } from './filtersSlice';

describe('filtersSlice', () => {
  const makeStore = () => createStore(createFiltersSlice);

  it('starts with no active filters', () => {
    const store = makeStore();
    expect(store.getState().activeFilters).toEqual([]);
  });

  it('sets active filters', () => {
    const store = makeStore();
    store.getState().setFilters(['critical', 'high']);
    expect(store.getState().activeFilters).toEqual(['critical', 'high']);
  });

  it('replaces filters — does not append', () => {
    const store = makeStore();
    store.getState().setFilters(['critical']);
    store.getState().setFilters(['high']);
    expect(store.getState().activeFilters).toEqual(['high']);
  });
});
```

